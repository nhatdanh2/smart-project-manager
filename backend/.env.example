# =============================================================================
# Smart Student Project Manager — Backend env (copy to .env for local dev)
# =============================================================================

# ---- Database ---------------------------------------------------------------
# In production set this to the Postgres URL Railway provides, e.g.
#   postgresql://user:pass@host:port/railway
# Locally we default to SQLite for zero-config dev.
DATABASE_URL=sqlite:///./smart_project.db

# ---- Redis ------------------------------------------------------------------
# Required only when USE_CELERY=true.  In production point to the
# Railway Redis addon URL (rediss://... or redis://...).
REDIS_URL=redis://localhost:6379/0
USE_CELERY=false

# ---- Auth -------------------------------------------------------------------
# IMPORTANT: replace with a long random string in production
# (e.g. `python -c "import secrets; print(secrets.token_urlsafe(64))"`)
JWT_SECRET_KEY=please-change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Public URL -------------------------------------------------------------
# Used for SAML/OIDC callbacks.  In production set to the Railway URL
# (or your custom domain), e.g. https://api.your-app.up.railway.app
PUBLIC_BASE_URL=http://localhost:8000

# ---- CORS -------------------------------------------------------------------
# Comma-separated list of allowed origins.  Set to your Vercel URL in
# production, e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- App --------------------------------------------------------------------
# Set DEBUG=false in production
DEBUG=true

# ---- Anthropic AI -----------------------------------------------------------
# Leave empty to use stub fallback (offline responses)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- OpenAI (Whisper) -------------------------------------------------------
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# ---- Email digest -----------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---- File storage (S3) ------------------------------------------------------
S3_BUCKET_NAME=
S3_REGION=ap-southeast-1
S3_ENDPOINT_URL=
S3_PRESIGN_EXPIRES_SECONDS=900
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- Rate limiting ----------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AI=10/minute
RATE_LIMIT_UPLOAD=20/minute
RATE_LIMIT_AUTH=10/minute

# ---- Observability ----------------------------------------------------------
# Sentry — leave SENTRY_DSN empty to disable
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_RELEASE=
# OpenTelemetry — set endpoint to enable
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=smart-project-manager-api

# ---- GDPR -------------------------------------------------------------------
GDPR_DELETION_GRACE_DAYS=30

# ---- Meilisearch ------------------------------------------------------------
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=
