# Production env for docker-compose.prod.yml
# Generate JWT_SECRET_KEY with: openssl rand -hex 32
# Generate POSTGRES_PASSWORD with: openssl rand -hex 24

POSTGRES_DB=smart_project_db
POSTGRES_USER=spm
POSTGRES_PASSWORD=replace-me-with-a-strong-password
JWT_SECRET_KEY=replace-me-with-32-bytes-of-random-hex

# Public URLs (frontend hits the backend via the proxy)
NEXT_PUBLIC_API_URL=https://spm.example.com
NEXT_PUBLIC_WS_URL=wss://spm.example.com
NEXTAUTH_URL=https://spm.example.com
NEXTAUTH_SECRET=same-as-jwt-secret-or-different

# CORS — comma-separated origins the API allows
CORS_ORIGINS=https://spm.example.com

# AI — leave empty to use deterministic stubs
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=

# Rate limiting (per-user)
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AI=10/minute
RATE_LIMIT_UPLOAD=20/minute
RATE_LIMIT_AUTH=10/minute

# Observability — leave empty to disable
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
