# Copy to backend/.env (or root .env for Docker Compose)

# Database
DATABASE_URL=sqlite:///./smart_project.db
# For Docker Compose (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/smart_project_db

# Redis (optional - only required if USE_CELERY=true)
REDIS_URL=redis://localhost:6379/0
USE_CELERY=false

# Auth
JWT_SECRET_KEY=please-change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Anthropic AI (leave empty to use stub fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (Whisper for audio meeting transcription)
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# Email digest (Phase 3 stub - logs to stdout unless SMTP_HOST is set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Storage (S3-compatible; unused in dev, we save to /uploads)
S3_BUCKET_NAME=
S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
