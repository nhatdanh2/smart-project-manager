# =============================================================================
# Smart Student Project Manager — Frontend env (copy to .env.local for dev)
# =============================================================================

# ---- Backend URLs -----------------------------------------------------------
# In production point these to the deployed backend:
#   NEXT_PUBLIC_API_URL=https://api.your-app.up.railway.app
#   NEXT_PUBLIC_WS_URL=wss://api.your-app.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ---- NextAuth ---------------------------------------------------------------
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# ---- Sentry (Phase 7) -------------------------------------------------------
# Leave DSN empty to disable
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=0.0
NEXT_PUBLIC_SENTRY_RELEASE=
